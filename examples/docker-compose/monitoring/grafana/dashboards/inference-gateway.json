{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 2,
      "type": "stat",
      "title": "Requests (via gateway)",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(gen_ai_server_request_duration_seconds_count{gen_ai_provider_name=~\"$provider\", source=~\"$source\"}) or vector(0)",
          "legendFormat": "requests",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto"
      },
      "description": "Total chat-completion requests served by the gateway since pod start."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 3,
      "type": "stat",
      "title": "Input Tokens",
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(gen_ai_client_token_usage_sum{gen_ai_token_type=\"input\", gen_ai_provider_name=~\"$provider\", source=~\"$source\"}) or vector(0)",
          "legendFormat": "input",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto"
      },
      "description": "Cumulative input tokens across gateway traffic and pushed client metrics."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 4,
      "type": "stat",
      "title": "Output Tokens",
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(gen_ai_client_token_usage_sum{gen_ai_token_type=\"output\", gen_ai_provider_name=~\"$provider\", source=~\"$source\"}) or vector(0)",
          "legendFormat": "output",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto"
      },
      "description": "Cumulative output tokens across gateway traffic and pushed client metrics."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 5,
      "type": "stat",
      "title": "Tool Calls",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(inference_gateway_tool_calls_total{gen_ai_provider_name=~\"$provider\", source=~\"$source\"}) or vector(0)",
          "legendFormat": "tool calls",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto"
      },
      "description": "Tool calls observed in model responses plus pushed client tool calls."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 6,
      "type": "stat",
      "title": "Sources Reporting",
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count(count by(source) (gen_ai_client_token_usage_count{gen_ai_provider_name=~\"$provider\", source=~\"$source\"})) or vector(0)",
          "legendFormat": "sources",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto"
      },
      "description": "Distinct `source` label values currently reporting token usage (gateway + pushed clients)."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 7,
      "type": "gauge",
      "title": "Error Rate (5m)",
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "100 * (sum(rate(gen_ai_server_request_duration_seconds_count{error_type!=\"\", gen_ai_provider_name=~\"$provider\", source=~\"$source\"}[5m])) or vector(0)) / clamp_min(sum(rate(gen_ai_server_request_duration_seconds_count{gen_ai_provider_name=~\"$provider\", source=~\"$source\"}[5m])), 1e-10)",
          "legendFormat": "error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "showThresholdLabels": false
      },
      "description": "Share of gateway requests finishing with an error status over the last 5 minutes."
    },
    {
      "id": 8,
      "type": "row",
      "title": "Traffic",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 9,
      "type": "timeseries",
      "title": "Request Rate by Provider",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by(gen_ai_provider_name) (rate(gen_ai_server_request_duration_seconds_count{gen_ai_provider_name=~\"$provider\", source=~\"$source\"}[$__rate_interval]))",
          "legendFormat": "{{gen_ai_provider_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "reqps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 25,
            "spanNulls": true,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "pointSize": 6
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 10,
      "type": "timeseries",
      "title": "Request Latency by Provider",
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by(le, gen_ai_provider_name) (rate(gen_ai_server_request_duration_seconds_bucket{gen_ai_provider_name=~\"$provider\", source=~\"$source\"}[$__rate_interval])))",
          "legendFormat": "p95 {{gen_ai_provider_name}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by(gen_ai_provider_name) (rate(gen_ai_server_request_duration_seconds_sum{gen_ai_provider_name=~\"$provider\", source=~\"$source\"}[$__rate_interval])) / sum by(gen_ai_provider_name) (rate(gen_ai_server_request_duration_seconds_count{gen_ai_provider_name=~\"$provider\", source=~\"$source\"}[$__rate_interval]))",
          "legendFormat": "avg {{gen_ai_provider_name}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 25,
            "spanNulls": true,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "pointSize": 6
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 11,
      "type": "row",
      "title": "Token Usage",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 12,
      "type": "timeseries",
      "title": "Token Rate by Source",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by(source, gen_ai_token_type) (rate(gen_ai_client_token_usage_sum{gen_ai_provider_name=~\"$provider\", source=~\"$source\"}[$__rate_interval]))",
          "legendFormat": "{{source}} / {{gen_ai_token_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 25,
            "spanNulls": true,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "pointSize": 6
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "Tokens per second, split by where the measurement came from (gateway vs pushed clients)."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 13,
      "type": "bargauge",
      "title": "Total Tokens by Source & Model",
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by(source, gen_ai_request_model, gen_ai_token_type) (gen_ai_client_token_usage_sum{gen_ai_provider_name=~\"$provider\", source=~\"$source\"})",
          "legendFormat": "{{source}} / {{gen_ai_request_model}} / {{gen_ai_token_type}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "displayName": "${__series.name}",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "text": {
          "titleSize": 14,
          "valueSize": 18
        },
        "minVizHeight": 16,
        "maxVizHeight": 48
      },
      "description": "Cumulative token totals. Includes one-shot pushed metrics that rate() panels cannot show."
    },
    {
      "id": 14,
      "type": "row",
      "title": "Tool Calls",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 15,
      "type": "timeseries",
      "title": "Tool Call Rate by Type",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by(gen_ai_tool_type, source) (rate(inference_gateway_tool_calls_total{gen_ai_provider_name=~\"$provider\", source=~\"$source\"}[$__rate_interval]))",
          "legendFormat": "{{source}} / {{gen_ai_tool_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "cps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 25,
            "spanNulls": true,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "showPoints": "auto",
            "pointSize": 6
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 16,
      "type": "bargauge",
      "title": "Top Tools by Usage",
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "topk(10, sum by(gen_ai_tool_name, source) (inference_gateway_tool_calls_total{gen_ai_provider_name=~\"$provider\", source=~\"$source\"}))",
          "legendFormat": "{{source}} / {{gen_ai_tool_name}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "displayName": "${__series.name}",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "displayMode": "gradient",
        "orientation": "horizontal",
        "showUnfilled": true,
        "text": {
          "titleSize": 14,
          "valueSize": 18
        },
        "minVizHeight": 16,
        "maxVizHeight": 48
      },
      "description": "Cumulative tool-call counts by tool name and source."
    },
    {
      "id": 17,
      "type": "row",
      "title": "Pushed Client Metrics (OTLP push only)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 18,
      "type": "timeseries",
      "title": "Tool Execution Duration (p95)",
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by(le, source) (rate(gen_ai_execute_tool_duration_seconds_bucket{gen_ai_provider_name=~\"$provider\", source=~\"$source\"}[$__rate_interval])))",
          "legendFormat": "p95 {{source}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 25,
            "spanNulls": true,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "showPoints": "always",
            "pointSize": 6
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "Fed exclusively by clients pushing OTLP metrics to POST /v1/metrics (e.g. subscription clients). Empty until a client pushes this metric."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 19,
      "type": "timeseries",
      "title": "Client Operation Duration (p95)",
      "gridPos": {
        "x": 8,
        "y": 33,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by(le, source) (rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_provider_name=~\"$provider\", source=~\"$source\"}[$__rate_interval])))",
          "legendFormat": "p95 {{source}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 25,
            "spanNulls": true,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "showPoints": "always",
            "pointSize": 6
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "Fed exclusively by clients pushing OTLP metrics to POST /v1/metrics (e.g. subscription clients). Empty until a client pushes this metric."
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "id": 20,
      "type": "timeseries",
      "title": "Time to First Token / Chunk (p95)",
      "gridPos": {
        "x": 16,
        "y": 33,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
